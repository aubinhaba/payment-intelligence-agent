<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <conversionRule conversionWord="maskedMsg"
      converterClass="com.aubin.pia.infrastructure.security.PanMaskingConverter"/>

  <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
    <encoder class="net.logstash.logback.encoder.LogstashEncoder">
      <customFields>{"service":"payment-intelligence-agent"}</customFields>
      <fieldNames>
        <timestamp>timestamp</timestamp>
        <message>message</message>
        <logger>logger</logger>
        <level>level</level>
        <thread>thread</thread>
      </fieldNames>
      <includeMdcKeyName>correlationId</includeMdcKeyName>
      <includeMdcKeyName>transactionId</includeMdcKeyName>
      <includeMdcKeyName>anomalyId</includeMdcKeyName>
      <includeMdcKeyName>traceId</includeMdcKeyName>
      <includeMdcKeyName>spanId</includeMdcKeyName>
    </encoder>
  </appender>

  <root level="INFO">
    <appender-ref ref="JSON"/>
  </root>

</configuration>
